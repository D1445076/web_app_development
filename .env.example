# .env.example
# 複製此檔案為 .env 並填入實際值（.env 已加入 .gitignore，不會被 commit）

# Flask 應用程式金鑰（用於 session 加密與 flash 訊息）
# 請替換為隨機的長字串，例如：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Flask 執行環境：development | production
FLASK_ENV=development

# Flask debug 模式：True | False（production 請設為 False）
FLASK_DEBUG=True
